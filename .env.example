# Daydream Ops — ortam değişkenleri (şablon)
# Kopyalayın:  .env.local (yerel geliştirme, commit etmeyin)
# Vercel: Project → Settings → Environment Variables

# OpenAI — YALNIZCA sunucu tarafı (api/operator). Tarayıcıya GİTMEZ.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Eski Silent Operator bayrağı (artık gerekmez; /api/operator kullanılır)
# VITE_OPENAI_ENABLED=false
