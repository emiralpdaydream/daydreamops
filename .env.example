# Daydream Ops — ortam değişkenleri (şablon)
# Kopyalayın:  .env.local (yerel geliştirme, commit etmeyin)
# Vercel: Project → Settings → Environment Variables

# OpenAI — Operatör (api/operator) + Bağlantılar testi (api/openai-test)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google OAuth — Gmail gönderim (sunucu tarafı ONLY)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://YOUR_DOMAIN.vercel.app/api/google/callback
GOOGLE_TOKEN_SECRET=   # min 32 karakter rastgele — token cookie şifreleme
APP_URL=https://YOUR_DOMAIN.vercel.app

# Google Gemini — alternatif AI (isteğe bağlı)
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
